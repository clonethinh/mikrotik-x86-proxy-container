# ===== webuiproxymikrotik backend env =====
# Server
NODE_ENV=production
PORT=8088
HOST=0.0.0.0
LOG_LEVEL=info

# ===== Low CPU (router với nhiều proxy) =====
# LOW_CPU_MODE=true
# HUB_REQUEST_LOG=false
# LOGS_TAIL_ENABLED=false
# METRICS_ENABLED=false
# CONTAINER_LOGGING=false
# LOG_LEVEL=warn

# Auth (CHANGE in production)
JWT_SECRET=change-me-32-chars-minimum-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# SQLite
DATABASE_URL=file:/data/proxy.db

# ===== Mikrotik =====
# DEPLOY_TARGET: router | external
DEPLOY_TARGET=router

# Mikrotik REST API (preferred - faster than SSH)
MIKROTIK_HOST=127.0.0.1
MIKROTIK_API_USER=admin
MIKROTIK_API_PASS=your-mikrotik-password
MIKROTIK_REST_PORT=80
MIKROTIK_REST_SCHEME=http

# Mikrotik SSH (used for: .rsc import, file operations, container stop)
MIKROTIK_SSH_PORT=22
MIKROTIK_SSH_USER=admin
MIKROTIK_SSH_PASS=your-mikrotik-password

# Mikrotik WAN IP public (for external IP detection)
MIKROTIK_WAN_IP=113.22.235.52

# ===== 3proxy =====
THREEPROXY_IMAGE=ghcr.io/tarampampam/3proxy:2
THREEPROXY_TARBALL=disk1/3proxy.tar

# ===== Network defaults =====
PROXY_HTTP_PORT_BASE=20000
PROXY_SOCKS_PORT_BASE=21000
EXT_HTTP_PORT_BASE=30055
EXT_SOCKS_PORT_BASE=31055
VETH_NETWORK_BASE=172.18
BRIDGE_NAME=containers-veth

# ===== Health check =====
HEALTH_CHECK_INTERVAL_MS=60000
HEALTH_CHECK_TIMEOUT_MS=10000

# ===== Realtime =====
WS_PATH=/ws
ENABLE_REALTIME=true

# ===== Data dir (persistent) =====
DATA_DIR=/data
DISK1_DIR=disk1

# ===== Auto-proxy (infinite pppoe-out pool) =====
AUTO_PROXY_MODE=full
AUTO_PROXY_POLL_MS=20000
AUTO_PROXY_MAX_CONCURRENT=16
AUTO_PROXY_STALE_TTL_MS=1800000

# ===== Optional: telegram alert =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=