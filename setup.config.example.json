{
  "router": {
    "host": "your-router.duckdns.org",
    "sshUser": "admin",
    "sshPass": "CHANGE_ME",
    "sshPort": 22
  },
  "wan": {
    "host": "your-router.duckdns.org",
    "managementPppoe": "pppoe-wan"
  },
  "webui": {
    "adminUser": "admin",
    "adminPass": "admin123",
    "jwtSecret": "webuiproxymikrotik-change-in-prod-32chars-x",
    "port": 8088
  },
  "autoProxy": {
    "mode": "semi",
    "pollMs": 20000,
    "countdownMs": 8000,
    "maxConcurrent": 16,
    "staleTtlMs": 1800000
  },
  "network": {
    "bridge": "containers-veth",
    "vethBase": "172.18",
    "extHttpBase": 30055,
    "extSocksBase": 31055
  },
  "proxy": {
    "deployMode": "hub"
  },
  "threeProxy": {
    "tarball": "disk1/3proxy.tar",
    "hubTarball": "disk1/3proxy-hub.tar",
    "hubImage": "webuiproxymikrotik/3proxy-hub:2"
  },
  "mode": "fresh+cleanup",
  "options": {
    "skipBuild": false,
    "skipCleanup": false,
    "upload3proxyTar": false,
    "upload3proxyHubTar": true,
    "purgeDbOnFresh": true
  }
}