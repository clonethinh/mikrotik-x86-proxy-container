# Auto detect text files and normalize to LF
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.prisma text eol=lf
*.rsc text eol=lf

# Shell scripts (keep LF)
*.sh text eol=lf
*.bash text eol=lf

# Windows specific (keep CRLF if needed)
*.bat text eol=crlf
*.ps1 text eol=crlf
setup.bat text eol=crlf

# Binary files
*.tar binary
*.db binary
*.png binary
*.jpg binary
*.ico binary
